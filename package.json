{
  "name": "protowiki",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Tools, strategies, frameworks and resources for prototyping MediaWiki projects.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "lint": "eslint . --ext .ts,.vue",
    "snapshot:wiki-skins": "bash scripts/snapshot-wiki-skins.sh"
  },
  "dependencies": {
    "@wikimedia/codex": "^2.6.0",
    "@wikimedia/codex-design-tokens": "^2.6.0",
    "@wikimedia/codex-icons": "^2.6.0",
    "lottie-web": "^5.13.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^10.0.0",
    "postcss": "^8.5.12",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "unplugin-vue-router": "^0.10.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
